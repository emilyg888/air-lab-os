        </mxCell>
        <mxCell id="vQscuov0rRj8pPbwZavg-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#DAE8FC,#99CCFF);strokeColor=light-dark(#DAE8FC,#99CCFF);fontSize=20;labelPosition=center;verticalLabelPosition=top;align=center;verticalAlign=bottom;fontStyle=1;fontColor=light-dark(#000000,#000000);" value="Business Use Cases" vertex="1">
          <mxGeometry height="780" width="1510" x="-3770" y="330" as="geometry" />
        </mxCell>
        <mxCell id="vQscuov0rRj8pPbwZavg-37" parent="vQscuov0rRj8pPbwZavg-36" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#DAE8FC,#579ED1);strokeColor=light-dark(#DAE8FC,#99CCFF);fontSize=18;fontStyle=1;fontColor=light-dark(#000000,#000000);" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;Risk &amp;amp; Fraud&lt;/font&gt;&lt;br&gt;&lt;br&gt;Traditional: static rules, periodic refresh&lt;br&gt;&lt;br&gt;With Signal Engine:&lt;br&gt;• Discover new fraud signals continuously&lt;br&gt;• Reject weak patterns automatically&lt;br&gt;• Promote only proven signals&lt;br&gt;&lt;br&gt;Outcome: earlier detection, less rule sprawl, explainable decisions" vertex="1">
          <mxGeometry height="326.7567567567567" width="650.86" x="52.07" y="36.89108108108108" as="geometry" />
        </mxCell>
        <mxCell id="vQscuov0rRj8pPbwZavg-38" parent="vQscuov0rRj8pPbwZavg-36" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#DAE8FC,#579ED1);strokeColor=light-dark(#DAE8FC,#99CCFF);fontSize=18;fontStyle=1;fontColor=light-dark(#000000,#000000);" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;Customer &amp;amp; Revenue Analytics&lt;/font&gt;&lt;br&gt;&lt;br&gt;Problem: too many metrics, unclear drivers&lt;br&gt;&lt;br&gt;With Signal Engine:&lt;br&gt;• Generate → test → converge on key drivers&lt;br&gt;&lt;br&gt;Outcome:&lt;br&gt;• Identify true churn drivers&lt;br&gt;• Surface real upsell signals&lt;br&gt;• Move from dashboards → causal insight" vertex="1">
          <mxGeometry height="326.7567567567567" width="650.86" x="755" y="36.89108108108108" as="geometry" />
        </mxCell>
        <mxCell id="vQscuov0rRj8pPbwZavg-39" parent="vQscuov0rRj8pPbwZavg-36" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#DAE8FC,#579ED1);strokeColor=light-dark(#DAE8FC,#99CCFF);fontSize=18;fontStyle=1;fontColor=light-dark(#000000,#000000);" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;Healthcare / Clinical&lt;/font&gt;&lt;br&gt;&lt;br&gt;Problem: massive feature space, noisy signals&lt;br&gt;&lt;br&gt;With Signal Engine:&lt;br&gt;• Systematically reject weak indicators&lt;br&gt;• Isolate true predictors&lt;br&gt;&lt;br&gt;Outcome:&lt;br&gt;• Better deterioration detection&lt;br&gt;• Improved treatment insights&lt;br&gt;• Reduced risk from false signals" vertex="1">
          <mxGeometry height="326.7567567567567" width="650.86" x="52.07" y="416.3505405405405" as="geometry" />
        </mxCell>
        <mxCell id="vQscuov0rRj8pPbwZavg-40" parent="vQscuov0rRj8pPbwZavg-36" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#DAE8FC,#579ED1);strokeColor=light-dark(#DAE8FC,#99CCFF);fontSize=18;fontStyle=1;fontColor=light-dark(#000000,#000000);" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;Operations / IoT / Predictive Maintenance&lt;/font&gt;&lt;br&gt;&lt;br&gt;Problem: thousands of sensor signals, unclear relevance&lt;br&gt;&lt;br&gt;With Signal Engine:&lt;br&gt;• Test and validate sensor features&lt;br&gt;• Promote only useful signals&lt;br&gt;&lt;br&gt;Outcome:&lt;br&gt;• Better failure prediction&lt;br&gt;• Stronger anomaly detection&lt;br&gt;• Reduced noise and false alarms" vertex="1">
